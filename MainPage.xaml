<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GQ4.MainPage">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Menu" Order="Primary" Priority="0" Clicked="OnMenuClicked" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout
            Padding="20"
            Spacing="12">

            <Label Text="הסורק" FontAttributes="Bold" FontSize="22" />

            <Image x:Name="PhotoImage" HeightRequest="300" Aspect="AspectFit" />

            <HorizontalStackLayout Spacing="10">
                <Button Text="צלם" Clicked="OnTakePhotoClicked" />
                <Button Text="סרוק" Clicked="OnScanImageClicked" />
            </HorizontalStackLayout>

            <Label x:Name="ResultLabel" Text="תוצאות סריקה יופיעו כאן" />

            <HorizontalStackLayout    Padding="10"  Spacing="6">
                <Label x:Name="H0" Text="" FontAttributes="None" FontSize="18" />
                <Label x:Name="H1" Text="" FontAttributes="None" FontSize="18" />
                <Label x:Name="H2" Text="" FontAttributes="None" FontSize="18" />
                <Label x:Name="H3" Text="" FontAttributes="None" FontSize="18" />
                
                
            </HorizontalStackLayout>
            


        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
